# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Configuration
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_ID=""

# Sentry Configuration
VITE_SENTRY_DSN=""

# Security Configuration
# Master Recovery PIN — WAJIB diganti sebelum deploy. JANGAN gunakan 999999 atau 000000.
VITE_MASTER_PIN="GANTI_DENGAN_PIN_6_DIGIT_UNIK_TOKO_INI"

# Crypto Pepper: Secret string added to hashes (DO NOT CHANGE ONCE SET in production)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_CRYPTO_PEPPER="GENERATE_DULU_JANGAN_PAKAI_DEFAULT"

# ReCaptcha Enterprise Site Key for Firebase App Check
VITE_RECAPTCHA_SITE_KEY=""

# Telegram Watchdog Alerts (Used by server-side processes or Cloudflare Workers in the future)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
