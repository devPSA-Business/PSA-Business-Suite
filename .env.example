# =============================================================================
# PSA Business Suite — Environment Configuration
# =============================================================================
# JANGAN PERNAH commit file .env.local ke repository!
# Salin file ini: cp .env.example .env.local
# Lalu isi dengan kredensial asli Anda.
# =============================================================================

# ── Firebase Core (WAJIB) ─────────────────────────────────────────────────────
# Dapatkan dari: Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="1:your-sender-id:web:your-app-id"
VITE_FIREBASE_DATABASE_ID="(default)"

# ── Security & Kriptografi (WAJIB) ────────────────────────────────────────────
# CRYPTO_PEPPER: String rahasia yang ditambahkan ke hash PBKDF2.
# ⚠️  JANGAN UBAH setelah production — akan invalidate semua PIN!
# Generate: openssl rand -base64 32
VITE_CRYPTO_PEPPER="GANTI_DENGAN_STRING_ACAK_MINIMAL_32_KARAKTER"

# ── Monitoring & Alerting (Opsional) ─────────────────────────────────────────
# Sentry: Dapatkan dari sentry.io > Project Settings > DSN
VITE_SENTRY_DSN=""

# Telegram Alerting (via Firebase Cloud Functions Secrets)
# Setup: firebase functions:secrets:set TELEGRAM_BOT_TOKEN
# Setup: firebase functions:secrets:set TELEGRAM_CHAT_ID
# Variabel ini TIDAK perlu diset di .env.local — dikelola via Firebase Secrets
# TELEGRAM_BOT_TOKEN="your-bot-token"
# TELEGRAM_CHAT_ID="your-chat-id"

# ── Security Tambahan (Opsional) ──────────────────────────────────────────────
# reCAPTCHA v3 (untuk proteksi form login)
VITE_RECAPTCHA_SITE_KEY=""

# ── AI / NLQ Integration (Opsional) ──────────────────────────────────────────
# Gemini AI — digunakan untuk fitur Natural Language Query (NLQ)
# Lebih aman dikelola via Firebase Functions Secrets, bukan di client
# VITE_GEMINI_API_KEY="your-gemini-api-key"

# ── Development Only ─────────────────────────────────────────────────────────
# HMR: Set 'true' untuk menonaktifkan Hot Module Replacement (di AI Studio)
# DISABLE_HMR="false"
