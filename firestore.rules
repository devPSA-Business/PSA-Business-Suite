rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // PILLAR 0: Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // PILLAR 3: Helper Functions (Hardened)
    // ===============================================================

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAppCheckVerified() { return request.app != null; }
    function isHardened() { return isAppCheckVerified() && isVerified(); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidStockItem(data) {
        return data.name is string && data.name.size() <= 100
            && data.barcode is string && data.barcode.size() <= 50
            && data.category is string && data.category.size() <= 50
            && data.price is number && data.price >= 0
            && data.cost is number && data.cost >= 0
            && data.quantity is number && data.quantity >= 0
            && data.branchId is string && data.branchId.size() > 0;
    }

    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
        return isVerified() && (request.auth.token.role == 'ADMIN' || getUserData().role == 'ADMIN');
    }

    function isManager() {
        return isVerified() && (
          request.auth.token.role == 'ADMIN' || 
          request.auth.token.role == 'MANAGER' || 
          getUserData().role == 'ADMIN' || 
          getUserData().role == 'MANAGER'
        );
    }
    
    function belongsToBranch(data) {
      return data.branchId is string && data.branchId == getUserData().branchId;
    }

    function canAccessRecord(data) {
        return isVerified() && belongsToBranch(data);
    }

    function canWriteRecord() {
        return isVerified() && belongsToBranch(incoming());
    }

    // ===============================================================
    // PILLAR 1 & 2: Collection Specific Rules (Hardened)
    // ===============================================================

    // User profiles - Only owner or admin can read/write
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && incoming().get('role', 'KASIR') == 'KASIR') || 
        isAdmin()
      );
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && 
         incoming().get('role', existing().role) == existing().role &&
         incoming().get('branchId', existing().branchId) == existing().branchId) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // CORE BUSINESS DATA (Protected by Manager/Admin roles for critical writes)
    match /stock/{id} {
      allow read: if isHardened() && canAccessRecord(existing());
      allow create: if isHardened() && isManager() && isValidId(id) && isValidStockItem(incoming()) && belongsToBranch(incoming());
      allow update: if isHardened() && isManager() && isValidStockItem(incoming()) && incoming().branchId == existing().branchId && canAccessRecord(existing());
      allow delete: if isHardened() && isAdmin();
    }

    match /transactions/{id} {
      allow read: if isHardened() && canAccessRecord(existing());
      allow create: if isHardened() && canWriteRecord();
      // Transactions should be immutable for casiers
      allow update: if isHardened() && isAdmin();
      allow delete: if isHardened() && isAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isHardened() && isManager() && belongsToBranch(existing());
      allow create: if isHardened() && canWriteRecord();
      allow update, delete: if false; // IMMUTABLE
    }

    match /customers/{id} {
      allow read: if canAccessRecord(existing());
      allow create: if canWriteRecord();
      allow update: if canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isManager() && canAccessRecord(existing());
    }

    // SERVICE & ORDERS
    match /repair_services/{id} {
      allow read: if canAccessRecord(existing());
      allow create: if canWriteRecord();
      allow update: if canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isManager() && canAccessRecord(existing());
    }
    match /custom_orders/{id} { 
      allow read: if canAccessRecord(existing());
      allow create: if canWriteRecord();
      allow update: if canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isManager() && canAccessRecord(existing());
    }
    match /gold_buyback/{id} { 
      allow read: if isManager() && canAccessRecord(existing());
      allow create: if isManager() && canWriteRecord();
      allow update: if isManager() && canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isAdmin();
    }
    match /daily_gold_price/{id} {
      allow read: if isVerified();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }
    match /gold_liquidations/{id} { 
      allow read: if isManager() && canAccessRecord(existing());
      allow create: if isManager() && canWriteRecord();
      allow update: if isManager() && canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isAdmin();
    }

    // OPERATIONS & SHIFTS
    match /shifts/{id} {
      allow read: if canAccessRecord(existing());
      allow create: if canWriteRecord();
      allow update: if canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isAdmin();
    }
    match /shift_totals/{id} { 
      allow read: if isManager() && canAccessRecord(existing());
      allow create: if isManager() && canWriteRecord();
      allow update: if isManager() && canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isAdmin();
    }
    match /petty_cash/{id} {
      allow read: if isManager() && canAccessRecord(existing());
      allow create: if isManager() && canWriteRecord();
      allow update: if isManager() && canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isAdmin();
    }
    match /financial_closures/{id} { 
      allow read: if isManager() && canAccessRecord(existing()); 
      allow create: if isManager() && canWriteRecord(); 
    }

    // INFRA & SYSTEM
    match /device_controls/system_lock { 
      allow read: if isVerified(); 
      allow write: if isAdmin(); 
    }
    match /device_controls/{other} {
      allow read, write: if isAdmin();
    }
    
    match /dlq_alerts/{id} { 
      allow read, write: if isAdmin(); 
    }
    match /sync_events/{id} { 
      // F-07: Perketat sync_events wajib verifikasi branchId di resource & request.resource
      allow read: if isVerified() && resource.data.branchId == getUserData().branchId; 
      allow create: if isVerified() && request.resource.data.branchId == getUserData().branchId;
      allow update: if isVerified() && 
                    resource.data.branchId == getUserData().branchId &&
                    request.resource.data.branchId == getUserData().branchId;
      allow delete: if isVerified() && resource.data.branchId == getUserData().branchId;
    }
    match /fraud_anomalies/{id} { 
      allow read: if isManager() && belongsToBranch(existing()); 
      allow create: if canWriteRecord(); 
    }
    
    // TELEMETRY & LOGS
    match /telemetry_events/{id} { allow create: if isSignedIn(); }
    match /error_logs/{id} { allow create: if isSignedIn(); }
    match /ai_feedback_tickets/{id} { 
      allow read: if canAccessRecord(existing());
      allow create: if canWriteRecord();
    }
    
    match /appointments/{id} { 
      allow read: if canAccessRecord(existing());
      allow create: if canWriteRecord();
      allow update: if canAccessRecord(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isManager() && canAccessRecord(existing());
    }
    match /internal_notes/{id} { 
      allow read: if isManager() && canAccessRecord(existing());
      allow create: if isManager() && canWriteRecord();
    }
  }
}
