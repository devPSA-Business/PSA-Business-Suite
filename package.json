{
  "name": "psa-business-suite",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types server.ts",
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "build:staging": "vite build --mode staging",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting:staging",
    "deploy:prod": "npm run build && firebase deploy --only hosting:production",
    "deploy:preview": "npm run build:staging && firebase hosting:channel:deploy preview-$(date +%Y%m%d)",
    "clean": "rm -rf dist",
    "lint": "eslint src && tsc --noEmit",
    "lint:fix": "eslint src --fix",
    "prepare": "husky install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run tests/stress",
    "test:backup": "tsx scripts/validate_backup.ts",
    "audit:deps": "npm ls --production --depth=0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dexie": "^4.4.1",
    "dexie-export-import": "^4.4.0",
    "dexie-react-hooks": "^4.4.0",
    "express": "^5.2.1",
    "firebase": "^11.0.0",
    "glob": "^13.0.6",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-usb": "^1.0.14",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.2.5",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.4.3",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-remove-console": "^2.2.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "uuid": "^11.0.5",
    "@tootallnate/once": "^3.0.1"
  }
}
