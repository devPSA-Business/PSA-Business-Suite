rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // PILLAR 0: Global Safety Net (Default Deny)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // FOUNDATIONAL HELPERS (Hardened)
    // ===============================================================

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isHardened() { return isVerified(); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
        return isVerified() && (request.auth.token.role == 'ADMIN' || getUserData().role == 'ADMIN');
    }

    function isManager() {
        return isVerified() && (
          request.auth.token.role == 'ADMIN' || 
          request.auth.token.role == 'MANAGER' || 
          getUserData().role == 'ADMIN' || 
          getUserData().role == 'MANAGER'
        );
    }
    
    function belongsToBranch(data) {
      return data.branchId is string && data.branchId == getUserData().branchId;
    }

    // ===============================================================
    // HARDENED VALIDATION HELPERS
    // ===============================================================

    function isValidStockItem(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
            && data.barcode is string && data.barcode.size() > 0 && data.barcode.size() <= 50
            && data.category is string && data.category.size() > 0 && data.category.size() <= 50
            && data.price is number && data.price >= 0
            && data.cost is number && data.cost >= 0
            && data.quantity is number && data.quantity >= 0
            && data.branchId is string && data.branchId.size() > 0;
    }

    // ===============================================================
    // CORE COLLECTIONS
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && incoming().get('role', 'KASIR') == 'KASIR') || 
        isAdmin()
      );
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && 
         incoming().get('role', existing().role) == existing().role &&
         incoming().get('branchId', existing().branchId) == existing().branchId) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /stock/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && isManager() && isValidId(id) && isValidStockItem(incoming()) && belongsToBranch(incoming());
      allow update: if isHardened() && isManager() && isValidStockItem(incoming()) && incoming().branchId == existing().branchId && belongsToBranch(existing());
      allow delete: if isHardened() && isAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isHardened() && isManager() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update, delete: if false; // IMMUTABLE
    }

    match /customers/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    // SERVICE & ORDERS
    match /repair_services/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /transactions/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming()) && (incoming().get('secureData', '').size() <= 1000000);
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId && (incoming().get('secureData', '').size() <= 1000000);
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /shifts/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /petty_cash/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /gold_buyback/{id} {
      allow read: if isHardened() && isManager() && belongsToBranch(existing());
      allow create: if isHardened() && isManager() && belongsToBranch(incoming());
      allow update: if isHardened() && isManager() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /gold_liquidations/{id} {
      allow read: if isHardened() && isManager() && belongsToBranch(existing());
      allow create: if isHardened() && isManager() && belongsToBranch(incoming());
      allow update: if isHardened() && isManager() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /custom_orders/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }

    match /appointments/{id} {
      allow read: if isHardened() && belongsToBranch(existing());
      allow create: if isHardened() && belongsToBranch(incoming());
      allow update: if isHardened() && belongsToBranch(existing()) && incoming().branchId == existing().branchId;
      allow delete: if isHardened() && isManager() && belongsToBranch(existing());
    }
  }
}
